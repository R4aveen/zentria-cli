{
	"name": "zentria-cli",
	"version": "1.1.6",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"bundle": "npx esbuild source/cli.tsx --bundle --platform=node --format=esm --target=node22 --outfile=build/bundle.mjs --jsx=automatic --define:process.env.NODE_ENV=\\\"production\\\" --minify",
		"build:exe": "node scripts/build-exe.mjs",
		"test": "prettier --check . && xo && ava"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"axios": "^1.13.6",
		"conf": "^15.1.0",
		"docx": "^9.6.1",
		"dotenv": "^17.3.1",
		"ink": "^4.1.0",
		"ink-text-input": "^6.0.0",
		"meow": "^11.0.0",
		"pdf-to-printer": "^5.7.0",
		"puppeteer-core": "^24.39.0",
		"qrcode": "^1.5.4",
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/node": "^25.4.0",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"@yao-pkg/pkg": "^6.14.1",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"esbuild": "^0.27.3",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"png-to-ico": "^3.0.1",
		"prettier": "^2.8.7",
		"rcedit": "^5.0.2",
		"resedit": "^3.0.2",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
